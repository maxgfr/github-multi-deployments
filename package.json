{
  "name": "@maxgfr/multi-deployments",
  "private": true,
  "description": "Github action which lets you to handle deployments status with multiple environments",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "package": "ncc build lib/main.js --source-map --license licenses.txt",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "all": "pnpm run build && pnpm run package && pnpm run lint && pnpm run test",
    "prepare": "husky install",
    "lint-staged": "lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxgfr/github-multi-deployments.git"
  },
  "keywords": [
    "actions",
    "multi-deployments",
    "deployments"
  ],
  "author": "maxgfr",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.29.1",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vercel/ncc": "^0.44.1",
    "eslint": "^9.39.5",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.6",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "lint-staged": {
    "*.ts": "pnpm run format"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.27.0"
    }
  }
}
